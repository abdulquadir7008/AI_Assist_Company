DATABASE_URL="postgresql://rag_user:rag_password@localhost:5432/company_rag?schema=public"
API_PORT=4000
NEXT_PUBLIC_API_URL="http://localhost:4000"

CHROMA_URL="http://localhost:8000"
CHROMA_COLLECTION="company_documents"

DEFAULT_AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

HUGGINGFACE_API_KEY=""
HUGGINGFACE_CHAT_MODEL="meta-llama/Llama-3.1-8B-Instruct"
HUGGINGFACE_EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# --- Auth ---
# Required. Generate with: openssl rand -hex 32
JWT_SECRET=""
# Optional platform-level root admin (manages companies; no access to tenant content).
ROOT_ADMIN_EMAIL=""
ROOT_ADMIN_PASSWORD=""
# Set to "false" in production to disable the demo seed endpoint and demo login hints.
ENABLE_DEMO_SETUP="true"
NEXT_PUBLIC_DEMO_MODE="true"

# --- Email (verification codes). Leave empty to log codes to the API console (dev mode). ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Company RAG <no-reply@example.com>"
