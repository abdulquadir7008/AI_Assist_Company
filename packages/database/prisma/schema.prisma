generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentCategory {
  HR_POLICY
  PRODUCT
  TECHNICAL
  LEGAL
  TRAINING
  OTHER
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum AiProvider {
  OPENAI
  HUGGINGFACE
}

// Deprecated: superseded by Document.allowedRoles/allowedDepartments.
// Kept only as a classification hint for pre-RBAC documents in the admin UI.
enum Visibility {
  COMPANY
  SUPPORT
  ENGINEERING
  HR
  LEGAL
  LEADERSHIP
}

enum Role {
  ADMIN
  HR
  LEGAL
  MANAGER
  EMPLOYEE
  CONTRACTOR
}

enum Department {
  GENERAL
  ENGINEERING
  HR
  LEGAL
  SALES
  SUPPORT
  LEADERSHIP
}

enum AuditAction {
  ASK
  DOC_UPLOAD
  DOC_DOWNLOAD
  ROLE_CHANGE
  RECLASSIFY
  CHUNK_RECLASSIFY
  REGISTER
  VERIFY_EMAIL
  LOGIN
  USER_CREATE
  PASSWORD_CHANGE
  COMPANY_STATUS_CHANGE
  CHAT_UPLOAD
  DIGEST_SENT
  CONVERSATION_DELETE
}

enum DocumentSource {
  ADMIN
  CHAT
}

enum CompanyStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
}

model Company {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  status    CompanyStatus @default(PENDING_VERIFICATION)
  // Proactive digests: optional Slack incoming-webhook + master toggle.
  slackWebhookUrl String?
  digestsEnabled  Boolean  @default(true)
  users     User[]
  documents Document[]
  questions Question[]
  auditLogs AuditLog[]
  conversations Conversation[]
  digestRuns    DigestRun[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String?
  passwordHash       String?
  emailVerifiedAt    DateTime?
  mustChangePassword Boolean            @default(false)
  roles              Role[]             @default([EMPLOYEE])
  department         Department         @default(GENERAL)
  digestOptOut       Boolean            @default(false)
  companyId          String
  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  questions          Question[]
  conversations      Conversation[]
  verificationCodes  VerificationCode[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([companyId, email])
}

model VerificationCode {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model RootAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Document {
  id              String           @id @default(cuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title           String
  originalName    String
  mimeType        String
  sizeBytes       Int
  storagePath     String
  category        DocumentCategory @default(OTHER)
  visibility      Visibility       @default(COMPANY)
  // Access control: fail closed — a document nobody classified is admin-only.
  allowedRoles       Role[]       @default([ADMIN])
  allowedDepartments Department[] @default([])
  classifiedAt       DateTime?
  classifiedById     String?
  // Chat uploads are private to their uploader (owner lane) until reclassified.
  ownerId            String?
  source             DocumentSource @default(ADMIN)
  status          DocumentStatus   @default(UPLOADED)
  failureReason   String?
  chunks          DocumentChunk[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  companyId  String
  index      Int
  content    String
  tokenCount Int
  section    String?
  pageStart  Int?
  pageEnd    Int?
  // Chunk-level ACL override for mixed-sensitivity documents.
  // aclOverride distinguishes "inherit from document" from "override to nobody".
  aclOverride         Boolean      @default(false)
  overrideRoles       Role[]       @default([])
  overrideDepartments Department[] @default([])
  chromaId   String   @unique
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([documentId])
}

model Conversation {
  id        String     @id @default(cuid())
  companyId String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  questions Question[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([companyId, userId, updatedAt])
}

model Question {
  id         String     @id @default(cuid())
  companyId  String
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  provider   AiProvider
  question   String
  answer     String
  citations  Json
  createdAt  DateTime   @default(now())

  @@index([companyId])
  @@index([conversationId])
}

model DigestRun {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  periodStart   DateTime
  periodEnd     DateTime
  documentCount Int
  emailsSent    Int
  slackSent     Boolean
  createdAt     DateTime @default(now())

  @@index([companyId, periodEnd])
}

model AuditLog {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId        String?
  rolesSnapshot Role[]
  department    Department?
  action        AuditAction
  detail        Json
  createdAt     DateTime    @default(now())

  @@index([companyId, createdAt])
}
